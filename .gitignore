# DeckBoss — .gitignore
# ========================

# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
.wrangler/
.turbo/
*.tsbuildinfo

# Environment & secrets
.env
.env.local
.env.*.local
!.env.example

# Cloudflare
.dev.vars
.mf/

# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.eggs/
build/
develop-eggs/
sdist/
venv/
.venv/

# IDE / Editor
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-workspace
*.sublime-project

# OS files
.DS_Store
Thumbs.db
desktop.ini

# Testing / Coverage
coverage/
.nyc_output/
*.lcov

# Logs
*.log
npm-debug.log*

# Misc
.cache/
tmp/
